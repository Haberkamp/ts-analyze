{
  "name": "ts-analyze",
  "version": "1.0.0",
  "description": "Analyze TypeScript migration order for JavaScript and TypeScript projects.",
  "type": "module",
  "bin": {
    "ts-analyze": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "start": "node ./dist/index.js",
    "test": "vitest run",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [],
